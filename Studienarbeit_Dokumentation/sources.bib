@article{madnick_overview_2009,
	title = {Overview and Framework for Data and Information Quality Research},
	volume = {1},
	issn = {1936-1955, 1936-1963},
	url = {https://dl.acm.org/doi/10.1145/1515693.1516680},
	doi = {10.1145/1515693.1516680},
	abstract = {Awareness of data and information quality issues has grown rapidly in light of the critical role played by the quality of information in our data-intensive, knowledge-based economy. Research in the past two decades has produced a large body of data quality knowledge and has expanded our ability to solve many data and information quality problems. In this article, we present an overview of the evolution and current landscape of data and information quality research. We introduce a framework to characterize the research along two dimensions:
              topics
              and
              methods
              . Representative papers are cited for purposes of illustrating the issues addressed and the methods used. We also identify and discuss challenges to be addressed in future research.},
	pages = {1--22},
	number = {1},
